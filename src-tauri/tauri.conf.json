{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wingman",
  "version": "0.5.0",
  "identifier": "io.github.timmybott.wingman",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Wingman",
        "width": 1150,
        "height": 780,
        "minWidth": 820,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_UPDATER_PUBKEY_SEE_DOCS_RELEASING_MD",
      "endpoints": [
        "https://github.com/Timmybott/Wingman/releases/latest/download/latest.json"
      ]
    }
  }
}
